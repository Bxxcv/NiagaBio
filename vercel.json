{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/register",
      "destination": "/register.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/profile",
      "destination": "/profile.html"
    },
    {
      "source": "/products",
      "destination": "/products.html"
    },
    {
      "source": "/links",
      "destination": "/links.html"
    },
    {
      "source": "/social",
      "destination": "/social.html"
    },
    {
      "source": "/gallery",
      "destination": "/gallery.html"
    },
    {
      "source": "/themes",
      "destination": "/themes.html"
    },
    {
      "source": "/checkout-settings",
      "destination": "/checkout-settings.html"
    },
    {
      "source": "/orders",
      "destination": "/orders.html"
    },
    {
      "source": "/upgrade",
      "destination": "/upgrade.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/maintenance",
      "destination": "/maintenance.html"
    },
    {
      "source": "/u/:username",
      "destination": "/u.html?username=:username"
    },
    {
      "source": "/checkout/:username/:product",
      "destination": "/checkout.html?username=:username&product=:product"
    }
  ]
}