{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/s/:username",
      "destination": "/api/share?username=:username"
    },
    {
      "source": "/s/:username/:product",
      "destination": "/api/share?username=:username&product=:product"
    },
    {
      "source": "/u/:username",
      "destination": "/pages/u.html?username=:username"
    },
    {
      "source": "/checkout/:username/:product",
      "destination": "/pages/checkout.html?username=:username&product=:product"
    },
    {
      "source": "/404",
      "destination": "/pages/404.html"
    },
    {
      "source": "/admin",
      "destination": "/pages/admin.html"
    },
    {
      "source": "/chatbot",
      "destination": "/pages/chatbot.html"
    },
    {
      "source": "/checkout-settings",
      "destination": "/pages/checkout-settings.html"
    },
    {
      "source": "/checkout",
      "destination": "/pages/checkout.html"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/dashboard.html"
    },
    {
      "source": "/gallery",
      "destination": "/pages/gallery.html"
    },
    {
      "source": "/links",
      "destination": "/pages/links.html"
    },
    {
      "source": "/login",
      "destination": "/pages/login.html"
    },
    {
      "source": "/maintenance",
      "destination": "/pages/maintenance.html"
    },
    {
      "source": "/notifications",
      "destination": "/pages/notifications.html"
    },
    {
      "source": "/orders",
      "destination": "/pages/orders.html"
    },
    {
      "source": "/privacy",
      "destination": "/pages/privacy.html"
    },
    {
      "source": "/products",
      "destination": "/pages/products.html"
    },
    {
      "source": "/profile",
      "destination": "/pages/profile.html"
    },
    {
      "source": "/refund",
      "destination": "/pages/refund.html"
    },
    {
      "source": "/register",
      "destination": "/pages/register.html"
    },
    {
      "source": "/reset-password",
      "destination": "/pages/reset-password.html"
    },
    {
      "source": "/social",
      "destination": "/pages/social.html"
    },
    {
      "source": "/terms",
      "destination": "/pages/terms.html"
    },
    {
      "source": "/themes",
      "destination": "/pages/themes.html"
    },
    {
      "source": "/u",
      "destination": "/pages/u.html"
    },
    {
      "source": "/upgrade",
      "destination": "/pages/upgrade.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=86400, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
